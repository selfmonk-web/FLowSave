{
  "manifest_version": 3,
  "name": "FlowSave — AI Conversation Checkpoints",
  "version": "1.0.0",
  "description": "Save named checkpoints of any AI chat. Rate, tag and annotate your best moments — restore them in one click.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
